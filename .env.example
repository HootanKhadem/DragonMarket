
# --- Postgres ---
POSTGRES_DB=dragonmarket
POSTGRES_USER=dragonmarket
POSTGRES_PASSWORD=dragonmarket
# Host port that maps to the container's 5432.
POSTGRES_PORT=5432

# --- App ---
# Host port that maps to the app container's PORT.
APP_PORT=8080
# Port the app listens on inside its container.
PORT=8080
# Must point at the "postgres" service name when running via docker-compose.
DATABASE_URL=postgres://dragonmarket:dragonmarket@postgres:5432/dragonmarket?sslmode=disable
ORACLE_REFRESH_INTERVAL=30s
AUCTION_SWEEP_INTERVAL=10s
